/*
This plugins renders "More options"/"Hide options" button, which toggles the visibility of toolbar menu sections in mobile view.
*/
CKEDITOR.plugins.add('collapsetoolbar',
{
    lang: ["co", "da", "de", "en-gb", "en-us", "es", "fi", "fr", "it", "lt", "nb", "nl", "nn-no", "pl", "pt-br", "sv", "tr"],

    init: function (editor)
    {
        var pluginName = editor.config.collapsetoolbar.Id,
            language = editor.lang[pluginName],
            extraSettings = editor.config.collapsetoolbar.ExtraSettings,
            visibleItemIndices = extraSettings && extraSettings.VisibleItemIndices ? extraSettings.VisibleItemIndices : [0, 1], //show only first 2 items by default
            kpiUrl = extraSettings && extraSettings.KpiUrl ? extraSettings.KpiUrl : undefined,
            kpiSection = extraSettings && extraSettings.KpiSection ? extraSettings.KpiSection : undefined,
            kpiMeasurement = extraSettings && extraSettings.KpiMeasurement ? extraSettings.KpiMeasurement : undefined,
            kpiContext = extraSettings && extraSettings.KpiContext ? extraSettings.KpiContext : undefined;

        editor.addCommand(pluginName,
        {
            exec: function (editor)
            {
                var toolbar = $(".cke_toolbox", editor.container.$),
                    menuLink = toolbar.find(".cke_button__collapsetoolbar"),
                    menuLabel = menuLink.find(".cke_button__collapsetoolbar_label"),
                    expanded = !toolbar.hasClass("ccl-texteditor-toobar-forceexpand");

                toolbar.toggleClass("ccl-texteditor-toobar-forceexpand");
                menuLabel.text(expanded ? language.hideOptions : language.moreOptions);
                menuLink.prop("title", expanded ? language.hideOptionsToolTip : language.moreOptionsToolTip);
                editor.fire("collapsetoolbar.toggle", { expanded: expanded });
                if (kpiUrl && kpiSection && kpiMeasurement && kpiContext)
                {
                    CommonFunctions.measureKpi(kpiUrl, kpiSection, kpiMeasurement, kpiContext);
                }
            }
        });

        // Add button to toolbar
        editor.ui.addButton('collapsetoolbar',
        {
            label: language.moreOptions,
            title: language.moreOptionsToolTip,
            command: pluginName
        });

        editor.on("instanceReady", function ()
        {
            var toolbar = $(".cke_toolbox", editor.container.$),
                menuLink = toolbar.find(".cke_button__collapsetoolbar")
            // Append CSS class to current button's section to prevent it from being hidden by media selector CSS.
            menuLink.parent().parent().addClass("ccl-texteditor-collapsetoolbar-section");
            toolbar.children().each(function (index, item)
            {
                if (visibleItemIndices.indexOf(index) < 0)
                {
                    $(item).addClass("ccl-texteditor-toobar-hideable");
                }
            });
            toolbar.show();
        });
    },
    afterInit: function (editor) {
        // Manual change to 'ready' state if an error occurs in the CKEditor. Bug ITS-27625
        if (CommonFunctions.isEdge() || CommonFunctions.isIe()) {
            // Use DOM event handler for catching CKEditor unexpected exceptions.
            window.onerror = function(error, url, line) {
                if(url.indexOf('ckeditor.js') !== -1){
                    setTimeout(function () {
                        for (var i in CKEDITOR.instances) {
                            var cke_editor = CKEDITOR.instances[i];

                            if (cke_editor.status === "loaded") {
                                cke_editor.status = "ready";
                                cke_editor.fire('instanceReady', null, cke_editor);
                            }
                        }

                        if (CKEDITOR.status === "loaded") {
                            CKEDITOR.status = "ready";
                            CKEDITOR.fire('instanceReady', null, cke_editor);
                        }
                    }, 200);
                }
            };
        }
    }
});